engine-strict=true

# Hoist `vite` (and rollup) to the top-level node_modules so SvelteKit, Vitest,
# vite-plugin-svelte and our own `vite.config.ts` all import the same TypeScript
# types. Without this, pnpm's strict isolation produces two structurally-identical
# but nominally-different `Plugin<any>` types, and svelte-check fails on
# `defineConfig({ plugins: [...] })`.
public-hoist-pattern[]=vite
public-hoist-pattern[]=rollup
