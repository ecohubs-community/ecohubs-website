# ─────────────────────────────────────────────────────────────────────────
# .env.example — required env vars for local dev AND for CI builds.
# Copy this file to `.env` and fill in real values for local dev.
# CI copies it verbatim to satisfy the SvelteKit static-private import contract.
#
# When you add or remove an env var anywhere under src/ that imports from
# `$env/static/private`, update this file too.
# ─────────────────────────────────────────────────────────────────────────

# ─── Public ──────────────────────────────────────────────────────────────
PUBLIC_SITE_URL=https://ecohubs.community
PUBLIC_TURNSTILE_SITE_KEY=
VITE_GA_MEASUREMENT_ID=

# ─── SMTP / email ────────────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@ecohubs.community
EMAIL_FROM_NAME=EcoHubs Community
EMAIL_REPLY_TO=hello@ecohubs.community
ADMIN_EMAIL=admin@ecohubs.community

# ─── Newsletter (Linkmonk) ───────────────────────────────────────────────
LINKMONK_URL=https://newsletter.ecohubs.community
LINKMONK_USERNAME=
LINKMONK_PASSWORD=

# ─── Newsletter (Mautic) ─────────────────────────────────────────────────
# Mautic form id for the single-field newsletter signup (field name
# `signup_email`). Used by the footer + scroll-triggered modal via
# /api/newsletter to dual-submit alongside Listmonk.
MAUTIC_NEWSLETTER_FORM_ID=

# ─── Waitlist (Mautic + Listmonk) ────────────────────────────────────────
# EcoHub 1 waitlist (/join-the-waitlist), submitted via /api/waitlist.
# MAUTIC_WAITLIST_FORM_ID — the Mautic form id both steps submit to (Mautic
#   upserts by email, so step 2 updates the contact step 1 created).
# LISTMONK_WAITLIST_LIST_ID — dedicated Listmonk list for waitlist signups,
#   kept separate from the newsletter list. Falls back to list 1 when unset.
MAUTIC_WAITLIST_FORM_ID=
LISTMONK_WAITLIST_LIST_ID=

# ─── ecohubsOS API ───────────────────────────────────────────────────────
# Members constellation (homepage) + application submission (/join).
ECOHUBSOS_API_URL=https://os.ecohubs.community
ECOHUBSOS_MEMBERS_API_KEY=
ECOHUBSOS_APPLICATIONS_API_KEY=

# ─── Cloudflare Turnstile ────────────────────────────────────────────────
# Leave blank in dev to disable the widget and skip server-side verification.
TURNSTILE_SECRET_KEY=

# ─── Ghost (blog source) ─────────────────────────────────────────────────
GHOST_URL=https://blog.ecohubs.community
GHOST_CONTENT_API_KEY=
GHOST_ADMIN_API_KEY=

# ─── Rate limiting (contact + newsletter endpoints) ──────────────────────
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX_REQUESTS=5

# ─── Google Analytics (server-side companion to VITE_GA_MEASUREMENT_ID) ──
GA_MEASUREMENT_ID=

# ─── Discord error alerts ────────────────────────────────────────────────
# Incoming webhook that server-side failures post to (contact email, the /join
# application submit, the Mautic/Listmonk signups — newsletter, self-assignment,
# waitlist — and any uncaught 500). Create it in Discord:
#   Channel → Edit Channel → Integrations → Webhooks → New Webhook → Copy URL.
# Leave blank to disable alerting (the expected state for local dev and CI).
DISCORD_ERRORS_WEBHOOK_URL=
